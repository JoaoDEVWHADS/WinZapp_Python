# Manual Trigger Commit - Rollback to edb0388
name: Release WinZapp

on:
  push:
    branches: [ main ]
  workflow_dispatch:
    inputs:
      version:
        description: "Versão da Release (Deixe em branco para usar a data/hora atual)"
        required: false
        type: string

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  release:
    runs-on: windows-latest
    permissions:
      contents: write

    steps:
      - name: Checkout Código-Fonte
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Definir Versão da Release
        shell: pwsh
        run: |
          $ver = "${{ inputs.version }}"
          if ([string]::IsNullOrEmpty($ver)) {
              $ver = Get-Date -Format "yyyy.MM.dd.HHmm"
          }
          echo "RELEASE_VERSION=$ver" | Out-File -FilePath $env:GITHUB_ENV -Encoding utf8 -Append
          Write-Output "[INFO] Versão definida para: $ver"

      - name: Atualizar versão no version.py
        shell: pwsh
        run: |
          $ver = "${{ env.RELEASE_VERSION }}"
          $filePath = "client/version.py"
          $content = "__version__ = `"$ver`""
          $content | Out-File -FilePath $filePath -Encoding utf8 -NoNewline
          Write-Output "[INFO] Arquivo version.py atualizado para a versão $ver."

      - name: Configurar Git, Commit e Tag
        shell: pwsh
        run: |
          $ver = "${{ env.RELEASE_VERSION }}"
          git config --local user.name "github-actions"
          git config --local user.email "github-actions@github.com"
          git add client/version.py
          git commit -m "chore: bump version to $ver [skip ci]"
          git tag "v$ver"
          git push origin HEAD:main
          git push origin "v$ver"
          Write-Output "[INFO] Alterações enviadas e tag v$ver criada."

      - name: Configurar Arquivos .env
        shell: pwsh
        run: |
          $envContent = @"
          WPPCONNECT_TAG_VERSION=2.10.0
          WPPCONNECT_API_MINIMUM_VERSION=2.10.0
          LICENSING_USER_EMAIL=gabrielhaberkamp@gmail.com
          "@
          $envContent | Out-File -FilePath ".env" -Encoding utf8
          $envContent | Out-File -FilePath "client/.env" -Encoding utf8
          Write-Output "[INFO] Arquivos .env criados para o build."

      - name: Configurar Python 3.13
        uses: actions/setup-python@v5
        with:
          python-version: '3.13'
          cache: 'pip'

      - name: Instalar Dependências do Python
        run: |
          python -m venv venv
          ./venv/Scripts/python -m pip install --upgrade pip
          ./venv/Scripts/pip install -r requirements.txt

      - name: Configurar MSYS2 (para gcc e windres)
        uses: msys2/setup-msys2@v2
        id: msys2
        with:
          msystem: UCRT64
          update: false
          install: >-
            mingw-w64-ucrt-x86_64-gcc
            mingw-w64-ucrt-x86_64-binutils

      - name: Adicionar MSYS2 GCC ao Path do Windows
        run: echo "${{ steps.msys2.outputs.msys2-location }}\ucrt64\bin" | Out-File -FilePath $env:GITHUB_PATH -Encoding utf8 -Append

      - name: Copiar DLL do bassopus para client/lib
        run: |
          New-Item -ItemType Directory -Force client\lib | Out-Null
          # bassopus.dll already committed in client/lib/ — verify both names exist
          if (Test-Path "client\lib\bass_opus.dll") {
            Copy-Item "client\lib\bass_opus.dll" "client\lib\bassopus.dll" -Force
            Write-Output "[INFO] bassopus.dll copied from bass_opus.dll"
          }
          if (Test-Path "client\lib\bassopus.dll") {
            Write-Output "[INFO] bassopus.dll is present in client/lib"
          } else {
            Write-Warning "[WARN] bassopus.dll not found in client/lib — OGG Opus playback will fail"
          }

      - name: Cache Node.js Portátil
        id: cache-node
        uses: actions/cache@v4
        with:
          path: client/node
          key: node-portable-v24.15.0

      - name: Baixar e Extrair Node.js Portátil
        if: steps.cache-node.outputs.cache-hit != 'true'
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Force -Path "client/node"
          Invoke-WebRequest -Uri "https://nodejs.org/dist/v24.15.0/node-v24.15.0-win-x64.zip" -OutFile "node-portable.zip"
          Expand-Archive -Path "node-portable.zip" -DestinationPath "node-temp"
          Copy-Item -Path "node-temp\node-v24.15.0-win-x64\*" -Destination "client/node" -Recurse -Force
          Remove-Item -Recurse -Force "node-temp", "node-portable.zip"

      - name: Cache Node Modules da WPPConnect API
        id: cache-api-modules
        uses: actions/cache@v4
        with:
          path: client/api/node_modules
          key: npm-packages-${{ hashFiles('client/api/package.json') }}
          restore-keys: |
            npm-packages-

      - name: Configurar WPPConnect API
        shell: pwsh
        run: |
          # 1. Clonar a API se não existir
          python setup_api.py
          
          # 2. Configurar caminhos para usar o Node portátil para instalar dependências
          cd client/api
          $nodeExe = "../../client/node/node.exe"
          $npmCli = "../../client/node/node_modules/npm/bin/npm-cli.js"
          
          # Adiciona o diretório do node ao PATH temporariamente
          $env:PATH = "$(Resolve-Path ../../client/node);$env:PATH"
          
          # Se o cache de node_modules falhar ou não existir, faz a instalação limpa
          if ("${{ steps.cache-api-modules.outputs.cache-hit }}" -ne "true") {
              &$nodeExe $npmCli install --no-audit --no-fund
          }
          
          # Compilar a API
          &$nodeExe $npmCli run build

      - name: Compilar WinZapp com PyInstaller e Gerar Instalador
        shell: pwsh
        run: |
          python build.py

      - name: Criar GitHub Release e Fazer Upload dos Assets
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v${{ env.RELEASE_VERSION }}
          name: Versão ${{ env.RELEASE_VERSION }}
          files: |
            dist/WinZappInstaller.exe
            dist/WinZapp.zip
          generate_release_notes: true