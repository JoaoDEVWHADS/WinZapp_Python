name: Release WinZapp

on:
  push:
    branches: [ main ]
  workflow_dispatch:
    inputs:
      version:
        description: "Versão da Release (Deixe em branco para usar a data/hora atual)"
        required: false
        type: string

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  release:
    runs-on: windows-latest
    permissions:
      contents: write

    steps:
      - name: Checkout Código-Fonte
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Definir Versão da Release
        shell: pwsh
        run: |
          $ver = "${{ inputs.version }}"
          if ([string]::IsNullOrEmpty($ver)) {
              $ver = Get-Date -Format "yyyy.MM.dd.HHmm"
          }
          echo "RELEASE_VERSION=$ver" | Out-File -FilePath $env:GITHUB_ENV -Encoding utf8 -Append
          Write-Output "[INFO] Versão definida para: $ver"

      - name: Atualizar versão no version.py
        shell: pwsh
        run: |
          $ver = "${{ env.RELEASE_VERSION }}"
          $filePath = "client/version.py"
          $content = "__version__ = `"$ver`""
          $content | Out-File -FilePath $filePath -Encoding utf8 -NoNewline
          Write-Output "[INFO] Arquivo version.py atualizado para a versão $ver."

      - name: Configurar Git, Commit e Tag
        shell: pwsh
        run: |
          $ver = "${{ env.RELEASE_VERSION }}"
          git config --local user.name "github-actions"
          git config --local user.email "github-actions@github.com"
          git add client/version.py
          git commit -m "chore: bump version to $ver [skip ci]"
          git tag "v$ver"
          git push origin HEAD:main
          git push origin "v$ver"
          Write-Output "[INFO] Alterações enviadas e tag v$ver criada."

      - name: Configurar Arquivos .env
        shell: pwsh
        run: |
          $envContent = @"
          WPPCONNECT_TAG_VERSION=2.10.0
          WPPCONNECT_API_MINIMUM_VERSION=2.10.0
          LICENSING_USER_EMAIL=gabrielhaberkamp@gmail.com
          "@
          $envContent | Out-File -FilePath ".env" -Encoding utf8
          $envContent | Out-File -FilePath "client/.env" -Encoding utf8
          Write-Output "[INFO] Arquivos .env criados para o build."

      - name: Configurar Python 3.13
        uses: actions/setup-python@v5
        with:
          python-version: '3.13'
          cache: 'pip'

      - name: Instalar Dependências do Python
        run: |
          python -m venv venv
          ./venv/Scripts/python -m pip install --upgrade pip
          ./venv/Scripts/pip install -r requirements.txt
          ./venv/Scripts/pip install zstandard pyinstaller

      - name: Configurar MSYS2 (para gcc, windres e opus)
        uses: msys2/setup-msys2@v2
        id: msys2
        with:
          msystem: UCRT64
          update: false
          install: >-
            mingw-w64-ucrt-x86_64-gcc
            mingw-w64-ucrt-x86_64-binutils
            mingw-w64-ucrt-x86_64-opus

      - name: Adicionar MSYS2 GCC ao Path do Windows
        run: echo "${{ steps.msys2.outputs.msys2-location }}\ucrt64\bin" | Out-File -FilePath $env:GITHUB_PATH -Encoding utf8 -Append

      - name: Copiar DLL do libopus e bassopus para client/lib
        run: |
          New-Item -ItemType Directory -Force client\lib | Out-Null
          Copy-Item "${{ steps.msys2.outputs.msys2-location }}\ucrt64\bin\libopus-0.dll" "client\lib\libopus-0.dll"
          if (Test-Path "client\lib\bass_opus.dll") {
            Copy-Item "client\lib\bass_opus.dll" "client\lib\bassopus.dll" -Force
          }

      - name: Cache Base QEMU Disk Image
        id: cache-qemu-disk
        uses: actions/cache@v4
        with:
          path: client/system/ubuntu-22.04.qcow2
          key: qemu-ubuntu-base-v1

      - name: Baixar Imagem Base QEMU se não houver Cache
        if: steps.cache-qemu-disk.outputs.cache-hit != 'true'
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Force -Path "client/system"
          # Download a pre-configured minimal Ubuntu 22.04 image with Docker pre-installed
          Invoke-WebRequest -Uri "https://github.com/JoaoDEVWHADS/WinZapp_Python/releases/download/vbase-image/ubuntu-22.04-base.qcow2" -OutFile "client/system/ubuntu-22.04.qcow2"

      - name: Instalar QEMU Portátil (Se não estiver em cache)
        id: cache-qemu-bin
        uses: actions/cache@v4
        with:
          path: client/qemu
          key: qemu-portable-win-v2

      - name: Baixar QEMU Portátil se não houver Cache
        if: steps.cache-qemu-bin.outputs.cache-hit != 'true'
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Force -Path "client/qemu"
          # Download portable QEMU windows binaries
          Invoke-WebRequest -Uri "https://qemu.weilbach.de/w64/qemu-w64-setup-20231220.exe" -OutFile "qemu-setup.exe"
          # Extract QEMU setup silently
          Start-Process -FilePath "qemu-setup.exe" -ArgumentList "/S /D=$(Resolve-Path client/qemu)" -Wait
          Remove-Item -Force "qemu-setup.exe"

      - name: Preparar contexto Docker da API
        run: |
          python setup_api.py

      - name: Setup Docker Buildx & Cache
        uses: docker/setup-buildx-action@v3

      - name: Build Docker Image and export to tar
        uses: docker/build-push-action@v5
        with:
          context: client/api
          tags: wppconnect-api:latest
          outputs: type=docker,dest=client/api/wppconnect-api.tar
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Injetar Imagem Docker no QCOW2
        shell: pwsh
        run: |
          # Copy QEMU bin folder to PATH for easy execution
          $env:PATH = "$(Resolve-Path client/qemu);$env:PATH"
          
          # Start QEMU headless VM in background
          $qemuProcess = Start-Process -FilePath "qemu-system-x86_64" -ArgumentList "-m 1024M -drive file=client/system/ubuntu-22.04.qcow2,format=qcow2 -net nic -net user,hostfwd=tcp::2222-:22 -nographic" -PassThru
          
          # Wait 20 seconds for boot
          Start-Sleep -Seconds 20
          
          # Transfer the Docker tar and execute docker load inside the VM (assumes default VM user/password)
          # using pscp and plink (comes with Putty, or we can use native OpenSSH scp/ssh on Windows runner)
          # OpenSSH is pre-installed on github actions windows runners.
          $sshOpts = "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p 2222"
          scp $sshOpts client/api/wppconnect-api.tar user@127.0.0.1:/home/user/wppconnect-api.tar
          ssh $sshOpts user@127.0.0.1 "docker load -i /home/user/wppconnect-api.tar && docker tag wppconnect-api:latest wppconnect-api:current && rm /home/user/wppconnect-api.tar"
          
          # Shutdown VM cleanly
          ssh $sshOpts user@127.0.0.1 "sudo poweroff"
          Wait-Process -Id $qemuProcess.Id

      - name: Compilar WinZapp e Gerar Instalador
        shell: pwsh
        run: |
          python build.py

      - name: Criar GitHub Release e Fazer Upload dos Assets
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v${{ env.RELEASE_VERSION }}
          name: Versão ${{ env.RELEASE_VERSION }}
          files: |
            dist/WinZappInstaller.exe
            dist/WinZapp.zip
          generate_release_notes: true
